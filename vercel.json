{
  "version": 2,
  "builds": [
    {
      "src": "node_backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "node_backend/server.js"
    },
    {
      "src": "/(.*).(js|css|png|jpg|jpeg|svg|ico|json|txt|map)",
      "dest": "frontend/package.json"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/package.json",
      "status": 200
    }
  ]
}
